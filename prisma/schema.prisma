// EngiShield AI - Prisma Schema
// Target: Neon PostgreSQL Serverless
// Normas: NR-1 (GRO/PGR), NR-9, NR-12, NR-17

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// IDENTITY & ACCESS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN_EMPRESA
  GESTOR_SEGURANCA
  TECNICO_SST
  AUDITOR_READONLY
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(TECNICO_SST)
  isActive     Boolean   @default(true) @map("is_active")
  empresaId    String?   @map("empresa_id")
  empresa      Empresa?  @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  refreshToken String?   @map("refresh_token")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  laudos    LaudoGRO[]
  auditorias AuditLog[]

  @@index([email])
  @@index([empresaId])
  @@map("users")
}

// ============================================================
// CORE ORGANIZATIONAL STRUCTURE
// ============================================================

enum RegimeTributario {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
}

model Empresa {
  id               String           @id @default(cuid())
  cnpj             String           @unique @db.VarChar(18)
  razaoSocial      String           @map("razao_social") @db.VarChar(255)
  nomeFantasia     String?          @map("nome_fantasia") @db.VarChar(255)
  cnaeCode         String           @map("cnae_code") @db.VarChar(10)
  cnaeDescricao    String           @map("cnae_descricao") @db.VarChar(255)
  grauRisco        Int              @map("grau_risco") @db.SmallInt
  regime           RegimeTributario @default(SIMPLES_NACIONAL)
  responsavelSST   String           @map("responsavel_sst") @db.VarChar(255)
  emailContato     String           @map("email_contato") @db.VarChar(255)
  telefoneContato  String?          @map("telefone_contato") @db.VarChar(20)
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  unidades   Unidade[]
  users      User[]
  laudos     LaudoGRO[]

  @@index([cnpj])
  @@index([grauRisco])
  @@map("empresas")
}

enum TipoUnidade {
  MATRIZ
  FILIAL
  DEPOSITO
  OBRA
  CAMPO
}

model Unidade {
  id           String      @id @default(cuid())
  empresaId    String      @map("empresa_id")
  empresa      Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nome         String      @db.VarChar(255)
  tipo         TipoUnidade @default(FILIAL)
  cep          String      @db.VarChar(9)
  logradouro   String      @db.VarChar(255)
  numero       String      @db.VarChar(20)
  complemento  String?     @db.VarChar(100)
  bairro       String      @db.VarChar(100)
  municipio    String      @db.VarChar(100)
  uf           String      @db.Char(2)
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  funcionarios Funcionario[]
  maquinas     Maquina[]
  riscos       Risco[]
  laudos       LaudoGRO[]

  @@index([empresaId])
  @@index([municipio, uf])
  @@map("unidades")
}

// ============================================================
// RECURSOS HUMANOS (NR-1, NR-7)
// ============================================================

enum SexoBiologico {
  MASCULINO
  FEMININO
  NAO_INFORMADO
}

enum VinculoEmpregaticio {
  CLT
  TEMPORARIO
  TERCEIRIZADO
  ESTAGIARIO
  PJ
}

model Funcionario {
  id                 String              @id @default(cuid())
  unidadeId          String              @map("unidade_id")
  unidade            Unidade             @relation(fields: [unidadeId], references: [id], onDelete: Cascade)
  cpf                String              @db.VarChar(14)
  nome               String              @db.VarChar(255)
  dataNascimento     DateTime            @map("data_nascimento") @db.Date
  sexo               SexoBiologico       @default(NAO_INFORMADO)
  cargo              String              @db.VarChar(100)
  cboCodigo          String              @map("cbo_codigo") @db.VarChar(10)
  cboDescricao       String              @map("cbo_descricao") @db.VarChar(255)
  vinculo            VinculoEmpregaticio @default(CLT)
  dataAdmissao       DateTime            @map("data_admissao") @db.Date
  dataDemissao       DateTime?           @map("data_demissao") @db.Date
  setorTrabalho      String              @map("setor_trabalho") @db.VarChar(100)
  jornadaHoras       Decimal             @map("jornada_horas") @db.Decimal(4, 2)
  isAtivo            Boolean             @default(true) @map("is_ativo")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  exposicoes ExposicaoRisco[]

  @@unique([cpf, unidadeId])
  @@index([unidadeId])
  @@index([cargo])
  @@index([isAtivo])
  @@map("funcionarios")
}

// ============================================================
// NR-12: MAQUINAS E EQUIPAMENTOS
// ============================================================

enum StatusMaquina {
  OPERACIONAL
  EM_MANUTENCAO
  INTERDITADA
  DESATIVADA
}

enum NivelRiscoMaquina {
  BAIXO
  MEDIO
  ALTO
  CRITICO
}

model Maquina {
  id                 String             @id @default(cuid())
  unidadeId          String             @map("unidade_id")
  unidade            Unidade            @relation(fields: [unidadeId], references: [id], onDelete: Cascade)
  tag                String             @db.VarChar(50)
  descricao          String             @db.VarChar(255)
  fabricante         String             @db.VarChar(100)
  modelo             String             @db.VarChar(100)
  anoFabricacao      Int                @map("ano_fabricacao") @db.SmallInt
  numeroDeSerie      String?            @map("numero_de_serie") @db.VarChar(100)
  potenciaKw         Decimal?           @map("potencia_kw") @db.Decimal(8, 2)
  status             StatusMaquina      @default(OPERACIONAL)
  nivelRisco         NivelRiscoMaquina  @default(MEDIO) @map("nivel_risco")
  dataUltimaInspecao DateTime?          @map("data_ultima_inspecao") @db.Date
  dataProximaInspecao DateTime?         @map("data_proxima_inspecao") @db.Date
  laudoNr12Url       String?            @map("laudo_nr12_url") @db.VarChar(500)
  observacoes        String?            @db.Text
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  naoConformidades NaoConformidade[]
  riscos           Risco[]

  @@unique([tag, unidadeId])
  @@index([unidadeId])
  @@index([status])
  @@index([nivelRisco])
  @@index([dataProximaInspecao])
  @@map("maquinas")
}

model NaoConformidade {
  id           String    @id @default(cuid())
  maquinaId    String    @map("maquina_id")
  maquina      Maquina   @relation(fields: [maquinaId], references: [id], onDelete: Cascade)
  descricao    String    @db.Text
  artigo_nr12  String    @map("artigo_nr12") @db.VarChar(50)
  dataIdentificacao DateTime @map("data_identificacao") @db.Date
  dataSanacao  DateTime? @map("data_sanacao") @db.Date
  sanada       Boolean   @default(false)
  evidenciaUrl String?   @map("evidencia_url") @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([maquinaId])
  @@index([sanada])
  @@map("nao_conformidades")
}

// ============================================================
// NR-9 / NR-17: RISCOS OCUPACIONAIS
// ============================================================

enum TipoRisco {
  FISICO
  QUIMICO
  BIOLOGICO
  ERGONOMICO
  ACIDENTE
  PSICOSSOCIAL
}

enum NivelExposicao {
  DESPREZIVEL
  BAIXO
  MEDIO
  ALTO
  MUITO_ALTO
}

model Risco {
  id              String         @id @default(cuid())
  unidadeId       String         @map("unidade_id")
  unidade         Unidade        @relation(fields: [unidadeId], references: [id], onDelete: Cascade)
  maquinaId       String?        @map("maquina_id")
  maquina         Maquina?       @relation(fields: [maquinaId], references: [id], onDelete: SetNull)
  tipo            TipoRisco
  descricao       String         @db.Text
  fonteGeradora   String         @map("fonte_geradora") @db.VarChar(255)
  trajetoria      String?        @db.VarChar(255)
  probabilidade   Int            @db.SmallInt
  severidade      Int            @db.SmallInt
  nivelRisco      NivelExposicao @map("nivel_risco")
  medidaControle  String?        @map("medida_controle") @db.Text
  epiRequerido    String[]       @map("epi_requerido")
  nrReferencia    String         @map("nr_referencia") @db.VarChar(20)
  localAplicacao  String         @map("local_aplicacao") @db.VarChar(255)
  ativo           Boolean        @default(true)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  exposicoes ExposicaoRisco[]

  @@index([unidadeId])
  @@index([tipo])
  @@index([nivelRisco])
  @@index([nrReferencia])
  @@map("riscos")
}

model ExposicaoRisco {
  id           String         @id @default(cuid())
  funcionarioId String        @map("funcionario_id")
  funcionario  Funcionario    @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  riscoId      String         @map("risco_id")
  risco        Risco          @relation(fields: [riscoId], references: [id], onDelete: Cascade)
  nivel        NivelExposicao
  horasExposicaoDia Decimal   @map("horas_exposicao_dia") @db.Decimal(4, 2)
  monitorado   Boolean        @default(false)
  dataInicio   DateTime       @map("data_inicio") @db.Date
  dataFim      DateTime?      @map("data_fim") @db.Date

  @@unique([funcionarioId, riscoId])
  @@index([funcionarioId])
  @@index([riscoId])
  @@map("exposicoes_risco")
}

// ============================================================
// NR-1: LAUDO GRO / PGR
// ============================================================

enum StatusLaudo {
  RASCUNHO
  EM_REVISAO
  APROVADO
  VIGENTE
  VENCIDO
  CANCELADO
}

model LaudoGRO {
  id               String      @id @default(cuid())
  empresaId        String      @map("empresa_id")
  empresa          Empresa     @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  unidadeId        String      @map("unidade_id")
  unidade          Unidade     @relation(fields: [unidadeId], references: [id], onDelete: Restrict)
  autorId          String      @map("autor_id")
  autor            User        @relation(fields: [autorId], references: [id], onDelete: Restrict)
  titulo           String      @db.VarChar(255)
  versao           String      @db.VarChar(20)
  status           StatusLaudo @default(RASCUNHO)
  dataElaboracao   DateTime    @map("data_elaboracao") @db.Date
  dataValidade     DateTime    @map("data_validade") @db.Date
  responsavelTecnico String    @map("responsavel_tecnico") @db.VarChar(255)
  creaOuCrpNumber  String?     @map("crea_ou_crp_number") @db.VarChar(50)
  conteudoJson     Json        @map("conteudo_json")
  hashDocumento    String?     @map("hash_documento") @db.VarChar(64)
  assinaturaUrl    String?     @map("assinatura_url") @db.VarChar(500)
  observacoes      String?     @db.Text
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@index([empresaId])
  @@index([unidadeId])
  @@index([status])
  @@index([dataValidade])
  @@map("laudos_gro")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  acao       String   @db.VarChar(100)
  entidade   String   @db.VarChar(100)
  entidadeId String   @map("entidade_id") @db.VarChar(100)
  payload    Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entidade, entidadeId])
  @@index([createdAt])
  @@map("audit_logs")
}
