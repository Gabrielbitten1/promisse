# Neon PostgreSQL Serverless
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/engishield?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/engishield?sslmode=require"

# Application
NODE_ENV="production"
PORT=3001
API_PREFIX="/api/v1"

# JWT Authentication
JWT_SECRET="your-256-bit-secret-key-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-256-bit-secret-key-here"
JWT_REFRESH_EXPIRES_IN="7d"

# Groq AI
GROQ_API_KEY="gsk_xxxx"
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.2

# CORS
ALLOWED_ORIGINS="https://app.engishield.com.br,https://www.engishield.com.br"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AI_MAX=20
